# ─────────────────────────────────────────────────────────────
# NCFE Web — environment variables
# Copy to `.env.local` for local dev. NEVER commit real secrets.
# Only NEXT_PUBLIC_* vars are exposed to the browser; keep everything
# else server-only.
# ─────────────────────────────────────────────────────────────

# Canonical public origin of the site (no trailing slash).
# Used for SEO canonical URLs, sitemap, robots and Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://www.ncfe.gov.in

# Backend API base URL (server-side calls). Leave blank until wired.
API_BASE_URL=

# Server-only secret used to sign/verify session tokens (HMAC-SHA256).
# REQUIRED in production — the app throws at runtime if this is missing.
# Generate a strong random value, e.g.:  openssl rand -base64 32
# Set this in the Netlify dashboard (Site settings → Environment variables),
# NOT in a committed file.
AUTH_SECRET=
